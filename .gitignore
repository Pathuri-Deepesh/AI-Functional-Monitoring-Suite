backend/data/db.sqlite-wal
backend/data/*.tmp

# Generated audit reports (regenerated on demand)
backend/data/reports/*.html

# Legacy migration backups
backend/data/*.bak
backend/data/*.migrated.bak
backend/data/urls.json

# Operating system files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Claude Code local cache (keep .mcp.json — project-level config)
.claude/cache/
